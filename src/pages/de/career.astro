---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { education, work } from "@/data/career-timeline.ts";
import Timeline from "@/components/Timeline.astro";
import { t, type Locale } from "@/i18n/ui";

const locale = (Astro.currentLocale ?? "en") as Locale;

const allEntries = [
  ...work.map((entry) => ({
    ...entry,
    lineColumn: 2,
    cardColumn: 1,
    cardLocation: "left" as "left" | "right",
    prefix: "work",
  })),
  ...education.map((entry) => ({
    ...entry,
    lineColumn: 4,
    cardColumn: 5,
    cardLocation: "right" as "left" | "right",
    prefix: "edu",
  })),
];
---

<BaseLayout title={t(locale, "nav.career")}>
  <section class="container">
    <h1>{t(locale, "nav.career")}</h1>
    <p>{t(locale, "home.career.subtitle")}</p>
  </section>

  <Timeline entries={allEntries} />
</BaseLayout>
