---
import HomeCareer from "@/components/HomeCareer.astro";
import HomeHero from "@/components/HomeHero.astro";
import HomeProjects from "@/components/HomeProjects.astro";
import HomeSkills from "@/components/HomeSkills.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t, type Locale } from "@/i18n/ui";

const locale = (Astro.currentLocale ?? "en") as Locale;
---

<BaseLayout>
  <HomeHero />

  <hr style="margin: 1.5rem 0" />

  <HomeCareer />

  <div class="container">
    <hr class="separator" />
  </div>

  <HomeProjects />

  <div class="container">
    <hr class="separator" />
  </div>

  <HomeSkills />

  <section class="container">
    <hr class="separator" />
    <p style="margin-top: 2.5rem">
      {t(locale, "home.cv.download")}
      {" "}
      &rarr; [<a class="underline" href="/documents/CV_english.pdf" download="CV_Andreas_Hell.pdf"
        >{t(locale, "home.cv.english")}</a
      >][<a class="underline" href="/documents/CV_deutsch.pdf" download="CV_Andreas_Hell.pdf"
        >{t(locale, "home.cv.german")}</a
      >]
    </p>
  </section>
</BaseLayout>

<style>
  .separator {
    margin: 1.5rem -1.5rem;
  }

  /* Mobile breakpoint */
  @media (max-width: 780px) {
    .separator {
      margin: 1.5rem -1rem;
    }
  }
</style>
