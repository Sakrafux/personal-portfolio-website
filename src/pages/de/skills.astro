---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SkillMatrix from "@/components/SkillMatrix.astro";
import { skillGroups, sortSkillGroups } from "@/data/skills.ts";
import { t, type Locale } from "@/i18n/ui";

const locale = (Astro.currentLocale ?? "en") as Locale;
const groups = sortSkillGroups(skillGroups);
---

<BaseLayout title={t(locale, "nav.skills")}>
  <section class="container">
    <h1>{t(locale, "nav.skills")}</h1>
    <p>{t(locale, "home.skills.subtitle")}</p>
  </section>

  <SkillMatrix groups={groups} />
</BaseLayout>
