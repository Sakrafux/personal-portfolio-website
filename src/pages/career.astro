---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { education, work } from "@/data/career-timeline.ts";
import Timeline from "@/components/Timeline.astro";

const allEntries = [
  ...work.map((entry) => ({
    ...entry,
    lineColumn: 2,
    cardColumn: 1,
    cardLocation: "left" as "left" | "right",
    prefix: "work",
  })),
  ...education.map((entry) => ({
    ...entry,
    lineColumn: 4,
    cardColumn: 5,
    cardLocation: "right" as "left" | "right",
    prefix: "edu",
  })),
];
---

<BaseLayout>
  <section class="container">
    <h1>Career</h1>
    <p>My professional journey through work and education.</p>
  </section>

  <Timeline entries={allEntries} />
</BaseLayout>
