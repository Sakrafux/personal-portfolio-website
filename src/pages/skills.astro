---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SkillMatrix from "@/components/SkillMatrix.astro";
import { skillGroups, sortSkillGroups } from "@/data/skills.ts";

const groups = sortSkillGroups(skillGroups);
---

<BaseLayout>
  <section class="container">
    <h1>Skills</h1>
    <p>Where and how much I have used each technology across work, education, and personal projects.</p>
  </section>

  <SkillMatrix groups={groups} />
</BaseLayout>
