---
import ThemePill from "./ThemePill.astro";
import LanguagePill from "./LanguagePill.astro";
import { t, type Locale } from "@/i18n/ui";
import { getLocalizedPath } from "@/i18n/routing.ts";

const locale = (Astro.currentLocale ?? "en") as Locale;
const links = [
  { href: getLocalizedPath("/", locale), label: t(locale, "nav.home") },
  { href: getLocalizedPath("/career", locale), label: t(locale, "nav.career") },
  { href: getLocalizedPath("/projects", locale), label: t(locale, "nav.projects") },
  { href: getLocalizedPath("/skills", locale), label: t(locale, "nav.skills") },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href;
---

<header>
  <nav class="container">
    <span class="brand">
      <svg viewBox="0 0 512 512" role="img" aria-label="Andreas Hell" width="36" height="36">
        <path
          fill="var(--color-accent)"
          d="M70 442V70H142.853V110.699H105.066V401.447H142.853V442H70Z"></path>
        <path
          fill="var(--color-accent)"
          d="M442 70V442H369.147V401.447H406.934V110.699H369.147V70H442Z"></path>
        <path
          fill="var(--color-text-primary)"
          d="M170.79 372V140H208.066V238.215H303.415V140H340.79V372H303.415V273.445H208.066V372H170.79Z"
        ></path>
      </svg>
      <span>Andreas Hell</span>
    </span>

    <div class="links">
      {
        links.map((link) => (
          <a
            class="muted-link"
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="tools">
      <ThemePill />
      <LanguagePill />
    </div>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
    </button>
  </nav>

  <div class="drawer-backdrop" data-hidden="true"></div>
  <aside class="drawer" id="mobile-drawer" data-hidden="true">
    <div class="drawer-links">
      {
        links.map((link) => (
          <a
            class="muted-link"
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="drawer-tools">
      <ThemePill />
      <LanguagePill />
    </div>
  </aside>
</header>

<script>
  const initDrawer = () => {
    const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
    const drawer = document.querySelector<HTMLElement>("#mobile-drawer");
    const backdrop = document.querySelector<HTMLElement>(".drawer-backdrop");

    if (!toggle || !drawer || !backdrop) return;
    if (toggle.dataset.bound === "true") return;
    toggle.dataset.bound = "true";

    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      drawer.setAttribute("aria-hidden", String(!open));
      drawer.setAttribute("data-hidden", String(!open));
      backdrop.setAttribute("data-hidden", String(!open));
      if (open) {
        document.body.style.overflow = "hidden";
        drawer.querySelector("a")?.focus();
      } else {
        document.body.style.overflow = "";
        toggle.focus();
      }
    };

    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    backdrop.addEventListener("click", () => setOpen(false));
    drawer.addEventListener("click", (e) => {
      if (e.target instanceof HTMLAnchorElement) setOpen(false);
    });

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
      }
    };
    document.addEventListener("keydown", onKeydown);

    // Close on resize past breakpoint so state stays in sync with CSS
    const mq = window.matchMedia("(min-width: 641px)");
    const onBreakpoint = (e: MediaQueryListEvent) => {
      if (e.matches) setOpen(false);
    };
    mq.addEventListener("change", onBreakpoint);

    // On the next swap, close the drawer and drop the document-level
    // listeners so they don't pile up across navigations. Element-scoped
    // listeners (toggle/backdrop/drawer) die with the replaced DOM.
    const onBeforeSwap = () => {
      setOpen(false);
      document.removeEventListener("keydown", onKeydown);
      mq.removeEventListener("change", onBreakpoint);
      document.removeEventListener("astro:before-swap", onBeforeSwap);
    };
    document.addEventListener("astro:before-swap", onBeforeSwap);
  };

  initDrawer();
  document.addEventListener("astro:page-load", initDrawer);
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    min-height: var(--navbar-height);
    background-color: var(--color-bg-main);
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }

  .brand img {
    display: block;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .links a {
    font-size: 0.95rem;
    font-weight: 500;
    font-family: var(--font-mono);
    padding: 0.25rem 0;
  }

  .links a[aria-current="page"] {
    color: var(--color-accent);
  }

  .tools {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .tools a,
  .tools span {
    font-size: 0.95rem;
    font-weight: 500;
    font-family: var(--font-mono);
    padding: 0.25rem 0;
    cursor: pointer;
  }

  /* Hamburger button — hidden on desktop, shown at <=780px */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 30px;
    padding: 0 10px;
    background: none;
    border: 0;
    cursor: pointer;
    z-index: 10;
  }

  .menu-toggle-bar {
    display: block;
    height: 2px;
    width: 100%;
    background-color: var(--color-text-muted);
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Drawer + backdrop */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  .drawer {
    display: none;
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: min(80vw, 300px);
    background-color: var(--color-bg-surface);
    border-left: 1px solid var(--color-border);
    transform: translateX(0);
    transition: transform 0.25s ease;
    padding: calc(var(--navbar-height) + 1rem) 1.5rem 1.5rem;
  }

  .drawer-backdrop[data-hidden="true"],
  .drawer[data-hidden="true"] {
    pointer-events: none;
  }

  .drawer-backdrop[data-hidden="true"] {
    opacity: 0;
  }

  .drawer[data-hidden="true"] {
    transform: translateX(100%);
  }

  .drawer-tools {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1rem;
    margin-top: 0.5rem;
  }

  .drawer-tools a {
    font-size: 1rem;
    font-weight: 500;
    font-family: var(--font-mono);
    padding: 0.25rem 0;
    cursor: pointer;
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer-links a {
    font-size: 1rem;
    font-weight: 500;
    font-family: var(--font-mono);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .drawer-links a[aria-current="page"] {
    color: var(--color-accent);
  }

  /* Mobile breakpoint */
  @media (max-width: 780px) {
    .links,
    .tools {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
    #mobile-drawer {
      display: block;
    }
  }
</style>
