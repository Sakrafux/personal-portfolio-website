---
import { education, work } from "@/data/career-timeline.ts";
import Timeline from "@/components/Timeline.astro";
import { t, type Locale } from "@/i18n/ui";
import { getLocalizedPath } from "@/i18n/routing";

const locale = (Astro.currentLocale ?? "en") as Locale;

const importantWork = work
  .filter((entry) => entry.important)
  .map((entry) => ({
    ...entry,
    lineColumn: 2,
    cardColumn: 1,
    cardLocation: "left" as "left" | "right",
    prefix: "work",
  }));

importantWork[1].rowAdjustment = 3;
importantWork[4].rowAdjustment = -2;

const importantEducation = education
  .filter((entry) => entry.important)
  .map((entry) => ({
    ...entry,
    lineColumn: 4,
    cardColumn: 5,
    cardLocation: "right" as "left" | "right",
    prefix: "edu",
  }));

importantEducation[1].rowAdjustment = 0;

const allEntries = [...importantWork, ...importantEducation];
---

<section class="container">
  <h1>{t(locale, "nav.career")}</h1>
  <p>{t(locale, "home.career.subtitle")}</p>
</section>

<Timeline entries={allEntries} rowHeight="10px" />

<section class="container">
  <p>
    {t(locale, "home.career.seeMore")}
    {" "}
    <a href={getLocalizedPath("/career", locale)} class="underline">{t(locale, "nav.career")}</a>
    {t(locale, "home.career.seeMorePage")}
  </p>
</section>
