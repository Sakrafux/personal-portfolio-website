---
import { projects, sortProjects } from "@/data/projects.ts";
import ProjectList from "@/components/ProjectList.astro";
import { t, type Locale } from "@/i18n/ui";
import { getLocalizedPath } from "@/i18n/routing";

const locale = (Astro.currentLocale ?? "en") as Locale;
const importantProjects = sortProjects(projects.filter((project) => project.important)).slice(0, 5);
---

<section class="container">
  <h1>{t(locale, "nav.projects")}</h1>
  <p>{t(locale, "home.projects.subtitle")}</p>

  <ProjectList projects={importantProjects} />
</section>

<section class="container">
  <p>
    {t(locale, "home.career.seeMore")}
    {" "}
    <a href={getLocalizedPath("/projects", locale)} class="underline">{t(locale, "nav.projects")}</a
    >
    {t(locale, "home.career.seeMorePage")}
  </p>
</section>
