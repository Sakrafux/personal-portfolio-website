---
import { getLocaleFromPath } from "@/i18n/routing.ts";
interface Props {
  withBorder?: boolean;
}

const { withBorder = false } = Astro.props;

const currentPath = Astro.url.pathname;
const activeLocale = getLocaleFromPath(currentPath);
const isDe = activeLocale === "de";

const links = [
  {
    href: "https://github.com/Sakrafux",
    label: "GitHub",
    icon: "github",
  },
  {
    href: "https://www.linkedin.com/in/andreas-hell-681939244",
    label: "LinkedIn",
    icon: "linkedin",
  },
  {
    href: "mailto:andhell03+portfolio@gmail.com",
    label: "Email",
    icon: "email",
  },
  {
    href: isDe ? "/documents/CV_deutsch.pdf" : "/documents/CV_english.pdf",
    label: "Download CV",
    icon: "cv",
  },
];
---

<div class="links">
  {
    links.map((link) => (
      <a
        class={`muted-link ${withBorder ? "with-border" : ""}`}
        href={link.href}
        target={link.icon === "cv" ? undefined : "_blank"}
        rel={link.icon === "cv" ? undefined : "noopener noreferrer"}
        download={link.icon === "cv" ? "CV_Andreas_Hell.pdf" : undefined}
        aria-label={link.label}
        title={link.label}
      >
        {link.icon === "github" && (
          <>
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="currentColor">
              <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.11-.75.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 2.9-.39c.98 0 1.97.13 2.9.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.07.78 2.16v3.2c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z" />
            </svg>
            <span>GitHub</span>
          </>
        )}
        {link.icon === "linkedin" && (
          <>
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z" />
            </svg>
            <span>LinkedIn</span>
          </>
        )}
        {link.icon === "email" && (
          <>
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m2 7 10 6 10-6" />
            </svg>
            <span>E-Mail</span>
          </>
        )}
        {link.icon === "cv" && (
          <>
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
