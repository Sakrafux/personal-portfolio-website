8.398438 13.976562 8.074219 14.6875 C 7.175781 15.042969 6.433594 15.476562 5.816406 16.007812 C 5.410156 16.355469 4.921875 16.886719 4.894531 17.441406 C 4.882812 17.703125 4.972656 17.941406 5.152344 18.132812 C 5.347656 18.335938 5.589844 18.445312 5.855469 18.445312 C 6.738281 18.445312 7.585938 17.234375 7.75 16.988281 C 8.070312 16.5 8.375 15.957031 8.671875 15.328125 C 9.421875 15.058594 10.21875 14.855469 10.992188 14.660156 L 11.269531 14.589844 C 11.476562 14.539062 11.691406 14.480469 11.914062 14.417969 C 12.148438 14.355469 12.390625 14.289062 12.636719 14.226562 C 13.429688 14.730469 14.285156 15.0625 15.117188 15.179688 C 15.816406 15.285156 16.441406 15.222656 16.863281 15.003906 C 17.242188 14.808594 17.261719 14.503906 17.253906 14.378906 Z M 18.960938 19.933594 C 18.960938 21.117188 17.917969 21.1875 17.707031 21.191406 L 4.257812 21.191406 C 3.082031 21.191406 3.011719 20.140625 3.007812 19.933594 L 3.007812 2.066406 C 3.007812 0.882812 4.050781 0.808594 4.257812 0.808594 L 13.34375 0.808594 L 13.347656 0.8125 L 13.347656 4.359375 C 13.347656 5.070312 13.78125 6.417969 15.410156 6.417969 L 18.929688 6.417969 L 18.960938 6.445312 Z M 18.125 5.609375 L 15.410156 5.609375 C 14.230469 5.609375 14.160156 4.566406 14.160156 4.359375 L 14.160156 1.625 Z M 19.769531 19.933594 L 19.769531 6.113281 L 14.160156 0.480469 L 14.160156 0.453125 L 14.132812 0.453125 L 13.679688 0 L 4.257812 0 C 3.546875 0 2.199219 0.433594 2.199219 2.066406 L 2.199219 19.933594 C 2.199219 20.648438 2.628906 22 4.257812 22 L 17.710938 22 C 18.421875 22 19.769531 21.566406 19.769531 19.933594 Z M 19.769531 19.933594 " />
            </svg>
            <span>CV</span>
          </>
        )}
      </a>
    ))
  }
</div>

<style>
  .links {
    display: flex;
    gap: 1.5rem;
  }

  .links a {
    display: flex;
    align-items: center;
  }

  .links a span {
    margin-left: 0.5rem;
  }

  .links a.with-border {
    padding: 0.5rem;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    transition: color 0s ease;
  }

  .links a.with-border:hover {
    border-color: var(--color-accent);
  }

  /* Mobile breakpoint */
  @media (max-width: 780px) {
    .links {
      flex-direction: column;
    }
  }
</style>
