---
import { Image } from "astro:assets";

import SocialLinks from "@/components/SocialLinks.astro";
import mountFuji from "@/assets/mount_fuji.jpg";
import { t, type Locale } from "@/i18n/ui";

const locale = (Astro.currentLocale ?? "en") as Locale;
const isDe = locale === "de";
---

<section class="hero-section">
  <div class="hero">
    <Image
      src={mountFuji}
      alt={isDe ? "Andreas am Mount Fuji" : "Andreas at Mount Fuji"}
      width={2000}
      height={612}
      loading="eager"
      decoding="async"
      fetchpriority="high"
      widths={[800, 1200, 2000]}
      sizes="(max-width: 1200px) 800px, 2000px"
    />

    <div class="overlay">
      <div class="copy">
        <h1>Andreas Hell</h1>
        <p class="title">{t(locale, "home.hero.title")}</p>
        <p class="tagline">{t(locale, "home.hero.tagline")}</p>
      </div>
    </div>
  </div>

  <div class="container">
    <p class="statement">
      {
        isDe ? (
          <>
            Ich baue <em>zuverlässige Software</em> über Frontend, Backend, Daten und Bereitstellung
            hinweg.
          </>
        ) : (
          <>
            I build <em>reliable software</em> across frontend, backend, data, and deployment.
          </>
        )
      }
    </p>
    <p>
      {
        isDe ? (
          <>
            Ich entwickle seit mehr als 10 Jahren Softwaresysteme und baue leidenschaftlich gerne
            Software, die nicht nur funktional ist, sondern von Ende zu Ende{" "}
            <em>zuverlässig und gut bedienbar</em> ist. Ich liebe das <em>Lösen von Problemen</em>,
            sei es die <em>Geschäftsprobleme</em> von Kunden, private Hobbyprojekte oder akademische
            Herausforderungen (resultierend in einem Abschluss mit Auszeichnung).
          </>
        ) : (
          <>
            I have been developing software systems for more than 10 years and enjoy building
            software that is not only functional but also <em>reliable and feels great to use</em>{" "}
            from end to end. I love <em>solving issues</em>, whether they be customers'{" "}
            <em>business problems</em>, private hobby projects, or academic challenges (resulting in
            graduation with distinction).
          </>
        )
      }
    </p>
    <p>
      {
        isDe ? (
          <>
            Ich bin am erfahrensten mit <em>Java, TypeScript und Go,</em> aber auch sehr flexibel
            und lerne gern dazu.
          </>
        ) : (
          <>
            I am most experienced with <em>Java, TypeScript, and Go</em> but also highly flexible
            and eager to learn more.
          </>
        )
      }
    </p>
    <SocialLinks withBorder />
  </div>
</section>

<style>
  .hero-section {
    margin-top: -1rem;
    margin-bottom: 1.5rem;
    min-height: calc(100vh - var(--navbar-height));
  }

  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .hero picture {
    display: contents;
  }

  .hero img {
    display: block;
    width: 100%;
    height: clamp(140px, 55vh - var(--navbar-height), 55vh - var(--navbar-height));
    object-fit: cover;
    object-position: center;
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: stretch;
    justify-content: flex-start;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0;
  }

  .copy {
    max-width: min(440px, 50%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1rem 1.5rem;
    text-align: left;
    background-color: rgb(from var(--color-bg-main) r g b / 50%);
    backdrop-filter: blur(4px);
  }

  .copy h1 {
    margin-bottom: 0.25rem;
    color: var(--color-text-primary);
    font-size: clamp(2.25rem, 7vw, 4.5rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .copy .title {
    margin-bottom: 0.5rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2.6vw, 1.75rem);
    letter-spacing: 0.02em;
  }

  .copy .tagline {
    margin-bottom: 0;
    color: var(--color-text-primary);
    font-size: clamp(0.95rem, 2.2vw, 1.25rem);
    font-style: italic;
  }

  .statement {
    color: var(--color-text-primary);
    font-size: clamp(2.25rem, 3rem, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
  }

  em {
    color: var(--color-accent);
    font-style: normal;
  }
</style>
