---
import type { TimelineEntryExtended } from "@/data/career-timeline.ts";
import TimelineColumn from "@/components/TimelineColumn.astro";

interface Props {
  entries: TimelineEntryExtended[];
  rowHeight?: string;
}

const { entries, rowHeight } = Astro.props;

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;
const nowDate = `${currentYear}-${String(currentMonth).padStart(2, "0")}`;

const monthIndex = (year: number, month: number) => year * 12 + (month - 1);
const currentMonthIdx = monthIndex(currentYear, currentMonth);

const parseDate = (dateStr: string) => {
  const [year, month] = dateStr.split("-").map(Number);
  return monthIndex(year, month);
};

entries.sort((a, b) => parseDate(b.end ?? nowDate) - parseDate(a.end ?? nowDate));

const earliestMonthIdx = Math.min(...entries.map((e) => parseDate(e.start))) - 1;
const earliestYear = Math.floor(earliestMonthIdx / 12);
const totalMonths = currentMonthIdx - earliestMonthIdx + 1;

// +1 for header; +1 because of CSS grid row indexing
const getRow = (dateStr: string) => currentMonthIdx - parseDate(dateStr) + 2;

const addMonth = (dateStr: string) => {
  let [year, month] = dateStr.split("-").map(Number);
  month++;
  if (month > 12) {
    month = 1;
    year++;
  }
  return `${year}-${String(month).padStart(2, "0")}`;
};

// Add a month for end dates, since they happen at the end of a month -> beginning of the next month
const getEndRow = (entry: TimelineEntryExtended) =>
  Math.max(getRow(entry.end ? addMonth(entry.end) : nowDate), 2);

interface YearRange {
  year: number;
  startRow: number;
  endRow: number;
}

const yearRanges: YearRange[] = [];
for (let y = currentYear; y >= earliestYear; y--) {
  const startM = Math.max(monthIndex(y, 1), earliestMonthIdx);
  const endM = Math.min(monthIndex(y, 12), currentMonthIdx);
  yearRanges.push({
    year: y,
    startRow: currentMonthIdx - endM + 2,
    endRow: currentMonthIdx - startM + 2,
  });
}
---

<section class="container timeline-wrapper">
  <div class="timeline-toggle" role="tablist" aria-label="Career timeline view">
    <button
      type="button"
      class="toggle-btn active"
      data-view="work"
      role="tab"
      aria-selected="true"
    >
      Work
    </button>
    <button type="button" class="toggle-btn" data-view="edu" role="tab" aria-selected="false">
      Education
    </button>
  </div>

  <div
    class="timeline"
    data-view="work"
    style={`grid-template-rows: auto repeat(${totalMonths}, var(--row-height)); ${rowHeight ? "--row-height: " + rowHeight : ""}`}
  >
    <h2 class="header work-header" style="grid-row: 1; grid-column: 1">Work</h2>
    <h2 class="header edu-header" style="grid-row: 1; grid-column: 5">Education</h2>

    {
      yearRanges
        .filter((yr) => monthIndex(yr.year, 1) >= earliestMonthIdx)
        .map((yr) => (
          <>
            <div class="year-boundary" data-type="work" style={`grid-row: ${yr.endRow}`} />
            <div class="year-boundary" data-type="edu" style={`grid-row: ${yr.endRow}`} />
          </>
        ))
    }

    {
      yearRanges.map((yr) => (
        <div
          class={`year ${yr.year === currentYear ? "current" : ""}`}
          style={`grid-row: ${yr.startRow} / ${yr.endRow + 1}`}
        >
          {yr.year}
        </div>
      ))
    }

    <div class="line" data-type="work" style={`grid-row: 2 / ${totalMonths + 2}`}></div>
    <div class="line" data-type="edu" style={`grid-row: 2 / ${totalMonths + 2}`}></div>

    <TimelineColumn entries={entries} getRow={getRow} getEndRow={getEndRow} />
  </div>
</section>

<style>
  .timeline-wrapper {
    padding: 0 1.5rem 1.5rem;
  }

  .timeline-toggle {
    display: none;
  }

  .timeline {
    --row-height: 20px;
    display: grid;
    grid-template-columns: 1fr 24px 70px 24px 1fr;
    position: relative;
  }

  .header {
    color: var(--color-text-primary);
    font-size: 1.1rem;
    font-weight: 600;
    font-family: var(--font-mono);
    padding-bottom: 1rem;
    border-bottom: none;
    margin-top: 0;
  }

  .work-header {
    text-align: right;
    padding-right: 1rem;
  }

  .edu-header {
    text-align: left;
    padding-left: 1rem;
  }

  .year-boundary {
    align-self: end;
    height: 0;
    border-top: 1px solid var(--color-border);
    z-index: 0;
  }

  .year-boundary[data-type="work"] {
    grid-column: 1 / 3;
  }

  .year-boundary[data-type="edu"] {
    grid-column: 4 / -1;
  }

  .year {
    grid-column: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-family: var(--font-mono);
    background-color: var(--color-bg-main);
    z-index: 2;
    padding-bottom: var(--row-height);
  }

  .year.current {
    color: var(--color-accent);
    font-weight: 600;
    opacity: 1;
  }

  .line {
    width: 2px;
    background-color: var(--color-border);
    justify-self: center;
    z-index: 1;
    position: relative;
  }

  .line[data-type="work"] {
    grid-column: 2;
  }

  .line[data-type="edu"] {
    grid-column: 4;
  }

  @media (max-width: 640px) {
    .timeline-wrapper {
      padding: 0 1rem 1.5rem;
    }

    .timeline-toggle {
      display: inline-flex;
      gap: 0.25rem;
      margin-bottom: 1.5rem;
      padding: 0.25rem;
      border: 1px solid var(--color-border);
      background-color: var(--color-bg-surface);
    }

    .toggle-btn {
      flex: 1;
      padding: 0.5rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--color-text-muted);
      background: none;
      border: 0;
      cursor: pointer;
      transition:
        color 0.2s ease,
        background-color 0.2s ease;
    }

    .toggle-btn.active {
      color: var(--color-bg-main);
      background-color: var(--color-accent);
    }

    .work-header,
    .edu-header {
      display: none;
    }

    .timeline {
      grid-template-columns: 1fr 24px 50px;
    }

    .timeline[data-view="edu"] {
      grid-template-columns: 50px 24px 1fr;
    }

    .year {
      grid-column: 3;
    }

    .timeline[data-view="edu"] .year {
      grid-column: 1;
    }

    .year-boundary {
      grid-column: 1 / -1;
    }

    .line {
      grid-column: 2;
    }

    .line[data-type="edu"] {
      grid-column: 2;
    }

    .timeline[data-view="work"] .line[data-type="edu"],
    .timeline[data-view="edu"] .line[data-type="work"] {
      display: none;
    }
  }
</style>

<script>
  const timeline = document.querySelector<HTMLElement>(".timeline")!;
  const toggle = document.querySelector<HTMLElement>(".timeline-toggle");

  if (timeline && toggle) {
    const buttons = Array.from(toggle.querySelectorAll<HTMLButtonElement>(".toggle-btn"));

    function setActiveButton(view: string) {
      buttons.forEach((b) => {
        const active = b.dataset.view === view;
        b.classList.toggle("active", active);
        b.setAttribute("aria-selected", String(active));
      });
    }

    function setView(view: string) {
      if (timeline.dataset.view === view) return;

      timeline.dataset.view = view;
      setActiveButton(view);
    }

    buttons.forEach((b) => b.addEventListener("click", () => setView(b.dataset.view ?? "work")));
  }
</script>
