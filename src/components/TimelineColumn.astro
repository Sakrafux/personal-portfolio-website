---
import type { TimelineEntryExtended } from "@/data/career-timeline.ts";
import { projects } from "@/data/projects.ts";

interface Props {
  entries: TimelineEntryExtended[];
  getRow: (dateStr: string) => number;
  getEndRow: (entry: TimelineEntryExtended) => number;
}

const { entries, getRow, getEndRow } = Astro.props;

const projectMap = new Map(projects.map((p) => [p.id, p.title]));

const monthNames = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];

const formatDate = (dateStr: string) => {
  const [year, month] = dateStr.split("-").map(Number);
  return `${monthNames[month - 1]} ${year}`;
};

const formatDateRange = (start: string, end: string | null) => {
  if (start === end) {
    return formatDate(start);
  }

  return `${formatDate(start)} — ${end ? formatDate(end) : "Present"}`;
};
---

{
  entries.map((entry, i) => {
    const { accentColor, cardLocation, prefix } = entry;

    const color =
      accentColor === "primary" ? "var(--color-accent)" : "var(--color-accent-secondary)";
    const colorHover =
      accentColor === "primary"
        ? "var(--color-accent-hover)"
        : "var(--color-accent-secondary-hover)";

    const id = `${prefix}-${i}`;
    // Somewhat confusing, but the timeline start is chronologically further in the past and
    // therefore at a higher row number
    const startRow = getRow(entry.start);
    const endRow = getEndRow(entry) - (entry.end ? 0 : 1);
    const differentMonths = entry.start !== entry.end;

    let rowAdjustment = entry.rowAdjustment ?? 0;
    if (!entry.end || !differentMonths) {
      rowAdjustment--;
    }

    return (
      <>
        {startRow > endRow && differentMonths && (
          <div
            class={`duration ${!entry.end ? "ongoing" : ""}`}
            data-entry-id={id}
            data-type={prefix}
            style={`grid-row: ${startRow + 2} / ${endRow + 1}; background-color: ${color}`}
          />
        )}
        <div
          class={`dot start ${entry.end ? "" : "active"}`}
          data-entry-id={id}
          data-type={prefix}
          style={`grid-row: ${startRow}; border-color: ${color}; --chosen-accent-color: ${color}`}
          title={formatDate(entry.start)}
        />
        {entry.end && differentMonths && (
          <div
            class="dot"
            data-entry-id={id}
            data-type={prefix}
            style={`grid-row: ${endRow}; border-color: ${color}; --chosen-accent-color: ${color}`}
            title={entry.end ? formatDate(entry.end) : "Present"}
          />
        )}
        <div
          class={`timeline-card ${cardLocation + "-card"}`}
          data-entry-id={id}
          data-type={prefix}
          tabindex="0"
          role="button"
          aria-expanded="false"
          style={`grid-row: ${endRow + rowAdjustment + 2}; --chosen-accent-color: ${color}; --chosen-accent-color-hover: ${colorHover}`}
        >
          <span class="date-range" style={`color: ${color}`}>
            {formatDateRange(entry.start, entry.end)}
          </span>
          <div class="card-header">
            {entry.icon && <img src={entry.icon} alt="" class="card-icon" width="32" height="32" />}
            <div class="card-titles">
              <h3>{entry.title}</h3>
              <span class="org">{entry.org}</span>
            </div>
          </div>
          {entry.description && <p>{entry.description}</p>}
          {entry.projectRefs && entry.projectRefs.length > 0 && (
            <div class="related-projects">
              <ul>
                {entry.projectRefs.map((ref) => {
                  const projectTitle = projectMap.get(ref);
                  if (!projectTitle) return null;
                  return (
                    <li>
                      <a href={`/projects#${ref}`} class="underline">
                        {projectTitle}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          )}
        </div>
      </>
    );
  })
}

<script>
  function toggleEntry(id: string) {
    const card = document.querySelector(`.timeline-card[data-entry-id="${id}"]`);
    if (!card) return;

    const isExpanded = card.classList.contains("expanded");

    document.querySelectorAll(".timeline-card.expanded").forEach((c) => {
      c.classList.remove("expanded");
      c.setAttribute("aria-expanded", "false");
    });
    document.querySelectorAll(".dot.selected").forEach((d) => d.classList.remove("selected"));
    document.querySelectorAll(".duration.selected").forEach((d) => d.classList.remove("selected"));

    if (!isExpanded) {
      card.classList.add("expanded");
      card.setAttribute("aria-expanded", "true");
      document
        .querySelectorAll(`.dot[data-entry-id="${id}"]`)
        .forEach((d) => d.classList.add("selected"));
      document
        .querySelectorAll(`.duration[data-entry-id="${id}"]`)
        .forEach((d) => d.classList.add("selected"));
    }
  }

  function handleInteraction(e: Event) {
    const target = (e.target as Element)?.closest("[data-entry-id]");
    if (!target) return;
    // Don't toggle the card when interacting with a link inside it
    if ((e.target as Element)?.closest(".related-projects a")) return;
    const id = target.getAttribute("data-entry-id");
    if (id) toggleEntry(id);
  }

  document.addEventListener("click", handleInteraction);

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Enter" && e.key !== " ") return;
    // Let links inside cards activate normally
    if ((e.target as Element)?.closest(".related-projects a")) return;
    handleInteraction(e);
    if ((e.target as Element)?.closest("[data-entry-id]")) e.preventDefault();
  });
</script>

<style>
  .duration {
    grid-column: var(--line-col);
    width: 2px;
    background-color: var(--color-accent);
    justify-self: center;
    align-self: start;
    height: calc(100% - var(--row-height));
    z-index: 2;
    position: relative;
  }

  .duration[data-type="work"] {
    --line-col: 2;
  }

  .duration[data-type="edu"] {
    --line-col: 4;
  }

  .duration.selected {
    width: 4px;
  }

  .dot {
    grid-column: var(--line-col);
    width: 12px;
    height: 12px;
    background-color: var(--color-bg-main);
    border: 2px solid var(--color-accent);
    justify-self: center;
    align-self: end;
    margin-bottom: -6px;
    z-index: 3;
    cursor: pointer;
  }

  .dot[data-type="work"] {
    --line-col: 2;
  }

  .dot[data-type="edu"] {
    --line-col: 4;
  }

  .dot.start {
    z-index: 4;
  }

  .dot.active {
    background-color: var(--color-accent);
    width: 14px;
    height: 14px;
    box-shadow: 0 0 0 4px rgba(0, 255, 194, 0.2);
    animation: pulse 2s ease-in-out infinite;
    z-index: 10;
  }

  .dot.selected {
    background-color: var(--chosen-accent-color);
    z-index: 5;
    cursor: pointer;
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px rgba(0, 255, 194, 0.2);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(0, 255, 194, 0.05);
    }
  }

  .timeline-card {
    grid-column: var(--card-col);
    --chosen-accent-color: var(--color-accent);
    --chosen-accent-color-hover: var(--color-accent-hover);
    width: calc(100% - 1rem);
    align-self: start;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    z-index: 4;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .timeline-card[data-type="work"] {
    --card-col: 1;
  }

  .timeline-card[data-type="edu"] {
    --card-col: 5;
  }

  .timeline-card:hover {
    border-color: var(--chosen-accent-color);
  }

  .timeline-card.expanded {
    z-index: 10;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    border-color: var(--chosen-accent-color);
  }

  .timeline-card:not(.expanded) .date-range,
  .timeline-card:not(.expanded) p,
  .timeline-card:not(.expanded) .related-projects {
    display: none;
  }

  .timeline-card:not(.expanded) .org {
    margin-bottom: 0;
  }

  .left-card {
    justify-self: end;
    text-align: right;
    margin-right: 1rem;
  }

  .right-card {
    justify-self: start;
    margin-left: 1rem;
  }

  .date-range {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    display: block;
    margin-bottom: 0.25rem;
  }

  .timeline-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.15rem;
  }

  .card-header {
    display: flex;
    align-items: start;
    gap: 0.75rem;
  }

  .left-card .card-header {
    flex-direction: row-reverse;
  }

  .card-icon {
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .card-titles {
    min-width: 0;
  }

  .org {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: block;
  }

  .timeline-card p {
    font-size: 0.88rem;
    margin-bottom: 0;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  .related-projects {
    margin-top: 0.5rem;
  }

  .related-label {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.25rem;
  }

  .related-projects ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .related-projects li {
    font-size: 0.82rem;
    line-height: 1.4;
    position: relative;
  }

  .related-projects a {
    color: var(--chosen-accent-color);
  }

  .related-projects a:hover {
    color: var(--chosen-accent-color-hover);
  }

  @media (prefers-reduced-motion: reduce) {
    .dot.active {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    :global(.timeline[data-view="work"]) [data-type="edu"],
    :global(.timeline[data-view="edu"]) [data-type="work"] {
      display: none;
    }

    :global(.timeline[data-view="edu"]) [data-type="edu"] {
      --line-col: 2;
      --card-col: 3;
    }
  }
</style>
