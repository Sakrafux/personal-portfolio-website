---
// TODO need to consider the fact that this is static, i.e., how can I show always an expanding timeline

// TODO sticky entries moving with the scrolling?

interface TimelineEntry {
  start: string;
  end: string | null;
  title: string;
  org: string;
  description: string;
  accentColor: string;
  lineColumn: number;
  cardColumn: number;
  cardLocation: "left" | "right";
  prefix: string;
}

interface Props {
  entries: TimelineEntry[];
  getRow: (dateStr: string) => number;
  getEndRow: (entry: TimelineEntry) => number;
}

const { entries, getRow, getEndRow } = Astro.props;

const monthNames = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];

const formatDate = (dateStr: string) => {
  const [year, month] = dateStr.split("-").map(Number);
  return `${monthNames[month - 1]} ${year}`;
};

const formatDateRange = (start: string, end: string | null) => {
  if (start === end) {
    return formatDate(start);
  }

  return `${formatDate(start)} — ${end ? formatDate(end) : "Present"}`;
};
---

{
  entries.map((entry, i) => {
    const { accentColor, lineColumn, cardColumn, cardLocation, prefix } = entry;

    const id = `${prefix}-${i}`;
    const startRow = getRow(entry.start);
    const endRow = getEndRow(entry) - (entry.end ? 0 : 1);
    const differentMonths = entry.start !== entry.end;

    return (
      <>
        {startRow > endRow && differentMonths && (
          <div
            class={`duration ${!entry.end ? "ongoing" : ""}`}
            style={`grid-row: ${startRow + 2} / ${endRow + 1}; grid-column: ${lineColumn}; background-color: ${accentColor}`}
          />
        )}
        <div
          class={`dot start ${entry.end ? "" : "active"}`}
          data-entry-id={id}
          style={`grid-row: ${startRow}; grid-column: ${lineColumn}; border-color: ${accentColor}; --chosen-accent-color: ${accentColor}`}
          title={formatDate(entry.start)}
        />
        {entry.end && differentMonths && (
          <div
            class="dot"
            style={`grid-row: ${endRow}; grid-column: ${lineColumn}; border-color: ${accentColor}`}
            title={entry.end ? formatDate(entry.end) : "Present"}
          />
        )}
        <div
          class={`timeline-card ${cardLocation + "-card"}`}
          data-entry-id={id}
          tabindex="0"
          role="button"
          aria-expanded="false"
          style={`grid-row: ${startRow}; grid-column: ${cardColumn}; --chosen-accent-color: ${accentColor}`}
        >
          <span class="date-range" style={`color: ${entry.accentColor}`}>
            {formatDateRange(entry.start, entry.end)}
          </span>
          <h3>{entry.title}</h3>
          <span class="org">{entry.org}</span>
          <p>{entry.description}</p>
        </div>
      </>
    );
  })
}

<script>
  function toggleEntry(id: string) {
    const card = document.querySelector(`.timeline-card[data-entry-id="${id}"]`);
    if (!card) return;

    const isExpanded = card.classList.contains("expanded");

    document.querySelectorAll(".timeline-card.expanded").forEach((c) => {
      c.classList.remove("expanded");
      c.setAttribute("aria-expanded", "false");
    });
    document.querySelectorAll(".dot.selected").forEach((d) => d.classList.remove("selected"));

    if (!isExpanded) {
      card.classList.add("expanded");
      card.setAttribute("aria-expanded", "true");
      document
        .querySelectorAll(`.dot[data-entry-id="${id}"]`)
        .forEach((d) => d.classList.add("selected"));
    }
  }

  function handleInteraction(e: Event) {
    const target = (e.target as Element)?.closest("[data-entry-id]");
    if (!target) return;
    const id = target.getAttribute("data-entry-id");
    if (id) toggleEntry(id);
  }

  document.addEventListener("click", handleInteraction);

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Enter" && e.key !== " ") return;
    handleInteraction(e);
    if ((e.target as Element)?.closest("[data-entry-id]")) e.preventDefault();
  });
</script>

<style>
  .duration {
    width: 2px;
    background-color: var(--color-accent);
    justify-self: center;
    align-self: start;
    height: calc(100% - var(--row-height));
    z-index: 2;
    position: relative;
  }

  .dot {
    width: 12px;
    height: 12px;
    background-color: var(--color-bg-main);
    border: 2px solid var(--color-accent);
    justify-self: center;
    align-self: end;
    margin-bottom: -6px;
    z-index: 3;
  }

  .dot.start {
    z-index: 4;
    cursor: pointer;
  }

  .dot.active {
    background-color: var(--color-accent);
    width: 14px;
    height: 14px;
    box-shadow: 0 0 0 4px rgba(0, 255, 194, 0.2);
    animation: pulse 2s ease-in-out infinite;
  }

  .dot.selected {
    background-color: var(--chosen-accent-color);
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px rgba(0, 255, 194, 0.2);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(0, 255, 194, 0.05);
    }
  }

  .timeline-card {
    --chosen-accent-color: var(--color-accent);
    align-self: start;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    z-index: 4;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .timeline-card:hover {
    border-color: var(--chosen-accent-color);
  }

  .timeline-card.expanded {
    z-index: 10;
    padding: 1rem 1.25rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    border-color: var(--chosen-accent-color);
  }

  .timeline-card:not(.expanded) .date-range,
  .timeline-card:not(.expanded) p {
    display: none;
  }

  .timeline-card:not(.expanded) .org {
    margin-bottom: 0;
  }

  .left-card {
    justify-self: end;
    text-align: right;
    margin-right: 1rem;
    max-width: 340px;
  }

  .right-card {
    justify-self: start;
    margin-left: 1rem;
    max-width: 340px;
  }

  .date-range {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    display: block;
    margin-bottom: 0.25rem;
  }

  .timeline-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.15rem;
  }

  .org {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .timeline-card p {
    font-size: 0.88rem;
    margin-bottom: 0;
    line-height: 1.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .dot.active {
      animation: none;
    }
  }
</style>
