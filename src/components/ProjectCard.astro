---
import type { Project } from "@/data/projects.ts";
import type { SkillContext } from "@/data/skills.ts";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const monthNames = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];

const formatDate = (dateStr: string) => {
  const [year, month] = dateStr.split("-").map(Number);
  return `${monthNames[month - 1]} ${year}`;
};

const formatDateRange = (start: string, end: string | null) => {
  if (start === end) {
    return formatDate(start);
  }

  return `${formatDate(start)} — ${end ? formatDate(end) : "Present"}`;
};

const contextLabel: Record<SkillContext, string> = {
  work: "Work",
  education: "Education",
  private: "Personal",
};

const contextColor: Record<SkillContext, string> = {
  work: "var(--color-accent)",
  education: "var(--color-accent-secondary)",
  private: "var(--color-text-muted)",
};
---

<article class="project-card">
  <div class="card-meta">
    <span
      class="context-badge"
      style={`color: ${contextColor[project.context]}; border-color: ${contextColor[project.context]}`}
    >
      {contextLabel[project.context]}
    </span>
    <span class="date-range">{formatDateRange(project.start, project.end)}</span>
  </div>

  <div class="card-header">
    <h3>{project.title}</h3>
    {project.org && <span class="org">{project.org}</span>}
  </div>

  <p>{project.description}</p>

  <ul class="skill-tags">
    {project.skills.map((skill) => <li>{skill}</li>)}
  </ul>

  {
    (project.links.repo || project.links.demo) && (
      <div class="card-links">
        {project.links.repo && (
          <a href={project.links.repo} class="underline" target="_blank" rel="noopener noreferrer">
            Repository &rarr;
          </a>
        )}
        {project.links.demo && (
          <a href={project.links.demo} class="underline" target="_blank" rel="noopener noreferrer">
            Demo &rarr;
          </a>
        )}
      </div>
    )
  }
</article>

<style>
  .project-card {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    padding: 1rem 1.25rem;
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-text-muted);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .context-badge {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid;
    padding: 0.1rem 0.5rem;
  }

  .date-range {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .card-header {
    margin-bottom: 0.5rem;
  }

  .project-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.15rem;
  }

  .org {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: block;
  }

  .project-card p {
    font-size: 0.92rem;
    line-height: 1.5;
    margin-bottom: 0;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .skill-tags li {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background-color: var(--color-bg-main);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.5rem;
  }

  .card-links {
    display: flex;
    gap: 1.25rem;
    margin-top: 0.75rem;
    font-size: 0.85rem;
  }
</style>
