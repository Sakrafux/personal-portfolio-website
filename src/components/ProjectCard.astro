---
import type { Project } from "@/data/projects.ts";
import type { SkillContext } from "@/data/skills.ts";

interface Props {
  project: Project;
  linkable?: boolean;
}

const { project, linkable = false } = Astro.props;

const headingId = linkable ? project.id : undefined;

const monthNames = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];

const formatDate = (dateStr: string) => {
  const [year, month] = dateStr.split("-").map(Number);
  return `${monthNames[month - 1]} ${year}`;
};

const formatDateRange = (start: string, end: string | null) => {
  if (start === end) {
    return formatDate(start);
  }

  return `${formatDate(start)} — ${end ? formatDate(end) : "Present"}`;
};

const contextLabel: Record<SkillContext, string> = {
  work: "Work",
  education: "Education",
  private: "Personal",
};

const contextColor: Record<SkillContext, string> = {
  work: "var(--color-accent)",
  education: "var(--color-accent-secondary)",
  private: "var(--color-text-muted)",
};

const maxVisibleSkills = 5;
const visibleSkills = project.skills.slice(0, maxVisibleSkills);
const hiddenSkills = project.skills.slice(maxVisibleSkills);
const hasHiddenSkills = hiddenSkills.length > 0;

const firstParagraph = project.description[0];
const extraParagraphs = project.description.slice(1);
const hasExtraParagraphs = extraParagraphs.length > 0;
---

<article class="project-card" id={headingId}>
  <div class="card-meta">
    <span
      class="context-badge"
      style={`color: ${contextColor[project.context]}; border-color: ${contextColor[project.context]}`}
    >
      {contextLabel[project.context]}
    </span>
    <span class="date-range">{formatDateRange(project.start, project.end)}</span>
  </div>

  <div class="card-header">
    <h3>
      {project.title}
      {
        linkable && (
          <a href={`#${headingId}`} class="heading-anchor" aria-label={`Link to ${project.title}`}>
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </svg>
          </a>
        )
      }
    </h3>
    {project.org && <span class="org">{project.org}</span>}
  </div>

  <div class="description-block">
    <p>{firstParagraph}</p>
    {extraParagraphs.map((paragraph) => <p class="paragraph-hidden">{paragraph}</p>)}
    {
      hasExtraParagraphs && (
        <button
          class="desc-toggle toggle-more"
          tabindex="0"
          role="button"
          aria-expanded="false"
          data-toggle-scope=".description-block"
        >
          Read more
        </button>
      )
    }
    {
      hasExtraParagraphs && (
        <button
          class="desc-toggle toggle-less"
          tabindex="0"
          role="button"
          aria-expanded="true"
          data-toggle-scope=".description-block"
        >
          Show less
        </button>
      )
    }
  </div>

  <ul class="skill-tags">
    {visibleSkills.map((skill) => <li>{skill}</li>)}
    {
      hasHiddenSkills && (
        <li
          class="skill-toggle toggle-more"
          tabindex="0"
          role="button"
          aria-expanded="false"
          data-toggle-scope=".skill-tags"
        >
          +{hiddenSkills.length} more
        </li>
      )
    }
    {hasHiddenSkills && hiddenSkills.map((skill) => <li class="skill-hidden">{skill}</li>)}
    {
      hasHiddenSkills && (
        <li
          class="skill-toggle toggle-less"
          tabindex="0"
          role="button"
          aria-expanded="true"
          data-toggle-scope=".skill-tags"
        >
          Show less
        </li>
      )
    }
  </ul>

  {
    (project.links.repo || project.links.demo) && (
      <div class="card-links">
        {project.links.repo && (
          <a href={project.links.repo} class="underline" target="_blank" rel="noopener noreferrer">
            Repository &rarr;
          </a>
        )}
        {project.links.demo && (
          <a href={project.links.demo} class="underline" target="_blank" rel="noopener noreferrer">
            Demo &rarr;
          </a>
        )}
        {project.links.doc && (
          <a href={project.links.doc} class="underline" target="_blank" rel="noopener noreferrer">
            Documentation &rarr;
          </a>
        )}
      </div>
    )
  }
</article>

<style>
  .project-card {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    padding: 1rem 1.25rem;
    transition: border-color 0.2s ease;
    scroll-margin-top: calc(var(--navbar-height) + 1rem);
  }

  .project-card:hover {
    border-color: var(--color-text-muted);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .context-badge {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid;
    padding: 0.1rem 0.5rem;
  }

  .date-range {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .card-header {
    margin-bottom: 0.75rem;
  }

  .project-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.15rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .heading-anchor {
    display: inline-flex;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity 0.15s ease;
    text-decoration: none;
  }

  .project-card h3:hover .heading-anchor,
  .heading-anchor:focus {
    opacity: 1;
  }

  .org {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: block;
  }

  .project-card p {
    font-size: 0.92rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .description-block:not(.expanded) .paragraph-hidden,
  .description-block:not(.expanded) .toggle-less {
    display: none;
  }

  .description-block.expanded .toggle-more {
    display: none;
  }

  .description-block .desc-toggle {
    cursor: pointer;
    user-select: none;
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    text-decoration: underline;
    margin-bottom: 0.5rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .skill-tags li {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background-color: var(--color-bg-main);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.5rem;
  }

  .skill-tags:not(.expanded) .skill-hidden,
  .skill-tags:not(.expanded) .toggle-less {
    display: none;
  }

  .skill-tags.expanded .toggle-more {
    display: none;
  }

  .skill-tags .skill-toggle {
    cursor: pointer;
    user-select: none;
    list-style: none;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    padding: 0;
    border: none;
    background: none;
    margin-left: 0.25rem;
    align-self: center;
    text-decoration: underline;
  }

  .card-links {
    display: flex;
    gap: 1.25rem;
    margin-top: 0.75rem;
    font-size: 0.85rem;
  }
</style>

<script>
  function toggleSection(toggle: Element) {
    const scope = toggle.getAttribute("data-toggle-scope");
    if (!scope) return;
    const container = toggle.closest(scope);
    if (!container) return;

    const isExpanded = container.classList.contains("expanded");

    if (isExpanded) {
      container.classList.remove("expanded");
      toggle.setAttribute("aria-expanded", "false");
    } else {
      container.classList.add("expanded");
      toggle.setAttribute("aria-expanded", "true");
    }
  }

  function handleToggleInteraction(e: Event) {
    const target = (e.target as Element)?.closest("[data-toggle-scope]");
    if (!target) return;
    e.stopPropagation();
    toggleSection(target);
  }

  document.addEventListener("click", handleToggleInteraction);

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Enter" && e.key !== " ") return;
    const target = (e.target as Element)?.closest("[data-toggle-scope]");
    if (!target) return;
    e.preventDefault();
    toggleSection(target);
  });
</script>
