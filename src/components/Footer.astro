---
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <SocialLinks />
    <p>&copy; {year} Andreas Hell</p>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  p {
    margin-bottom: 0;
    font-size: 0.9rem;
    font-family: var(--font-mono);
  }
</style>
